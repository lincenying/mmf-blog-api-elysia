TAG=1.26.0319

# ========================================
# 应用配置
# ========================================
# 应用程序名称
APP_NAME="MMF Blog API"
# 应用程序版本号
APP_VERSION="1.0.0"
# 应用程序描述
APP_DESCRIPTION="A modern web API built with Bun and ElysiaJS"

# ========================================
# 服务器配置
# ========================================
# 服务监听端口
PORT=4000
# 服务绑定的主机地址
HOST=0.0.0.0
# Node.js 运行环境 (可选值: development, production, test)
NODE_ENV=development
# 外部访问端口（用于 Docker 环境）
EXTERNAL_APP_PORT=4000
# 外部访问主机（用于 Docker 环境）
EXTERNAL_APP_HOST=127.0.0.1

# ========================================
# 日志配置
# ========================================
# 日志级别 (可选值: error, warn, info, debug, trace)
LOG_LEVEL=info

# ========================================
# CORS 配置
# ========================================
# 允许访问的源（支持多个域名用逗号分隔，或使用 * 表示所有源）
CORS_ORIGIN="*"
# 是否允许携带凭证
CORS_CREDENTIALS=true
# 允许的HTTP方法
CORS_METHODS="GET,POST,PUT,DELETE,OPTIONS"

# ========================================
# Swagger 文档配置
# ========================================
# Swagger文档访问路径
SWAGGER_PATH="/docs"
# API文档标题
SWAGGER_TITLE="MMF Blog API"
# API版本号
SWAGGER_VERSION="1.0.0"
# API描述信息
SWAGGER_DESCRIPTION="A modern web API built with Bun and ElysiaJS"

# ========================================
# 静态文件配置
# ========================================
# 静态资源文件路径
STATIC_ASSETS_PATH="./public"
# 静态资源URL前缀
STATIC_PREFIX="/public"

# MD5加密
# 如用户的密码是 123456, 存到数据库将会变成 md5('!@#$%(*&^)' + '123456')
MD5_SALT="!@#$%(*&^)"

