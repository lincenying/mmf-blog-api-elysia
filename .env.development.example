# 复制为 .env.development 后按需修改（勿提交含密钥的文件）

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# CORS（多个源用逗号分隔）
CORS_ORIGIN=http://localhost:5173,http://localhost:4000
CORS_CREDENTIALS=true

# JWT Cookie 有效期（秒）
JWT_EXPIRES_IN_SECONDS=2592000

# MongoDB
DATABASE_URL=mongodb://127.0.0.1:27017
MONGO_DB=mmfblog_v2

# 应用
MD5_SALT=!@#$%(*&^)
LOG_LEVEL=info
SWAGGER_PATH=/docs
