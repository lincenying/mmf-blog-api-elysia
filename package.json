{
  "name": "mmf-blog-api-elysia",
  "type": "module",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "build": "bun run build/build.ts",
    "build:compile:mac": "bun run build/build-mac.ts",
    "build:compile:linux": "bun run build/build-linux.ts",
    "build:compile:win": "bun run build/build-win.ts",
    "init:config": "bun run src/init.ts",
    "start": "bun run dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ts": "tsc --noEmit",
    "tsc": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
