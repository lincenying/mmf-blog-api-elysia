    "@elysiajs/server-timing": "^1.4.1",
    "@elysiajs/static": "^1.4.10",
    "@elysiajs/swagger": "^1.3.1",
    "@lincy/utils": "^0.7.3",
    "convict": "^6.2.5",
    "dayjs": "^1.11.21",
    "elysia": "^1.4.29",
    "highlight.js": "^11.11.1",
    "js-yaml": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.5.1",
    "markdown-it": "^14.2.0",
    "md5": "^2.3.0",
    "mongoose": "^9.7.2",
    "mongoose-autopopulate": "^1.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
