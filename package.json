{
  "name": "mmf-blog-api-elysia",
  "type": "module",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "build": "bun build --minify --outfile ./dist/index.js src/index.ts --target bun",
    "build:compile": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server src/index.ts",
    "init:config": "bun run src/init.ts",
    "start": "bun run dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ts": "tsc --noEmit",
    "tsc": "tsc"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/html": "^1.4.0",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/server-timing": "^1.4.0",
    "@elysiajs/static": "^1.4.7",
    "@elysiajs/swagger": "^1.3.1",
    "@lincy/utils": "^0.7.3",
    "convict": "^6.2.5",
    "dayjs": "^1.11.20",
    "elysia": "^1.4.28",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.2.7",
    "markdown-it": "^14.1.1",
    "md5": "^2.3.0",
    "mongoose": "^9.3.1",
    "mongoose-autopopulate": "^1.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "toml": "^3.0.0",
    "twig": "^2.0.0"
  },
  "devDependencies": {
    "@lincy/eslint-config": "^6.5.2",
    "@types/convict": "^6.1.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/markdown-it": "^14.1.2",
    "@types/md5": "^2.3.6",
    "@types/twig": "^1.12.17",
    "bun-types": "1.3.11",
    "jiti": "^2.6.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  }
}
