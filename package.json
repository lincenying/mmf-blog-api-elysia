    "@lincy/eslint-config": "^7.2.0",
    "@types/bun": "^1.3.14",
    "@types/convict": "^6.1.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/markdown-it": "^14.1.2",
    "@types/md5": "^2.3.6",
    "@types/twig": "^1.12.17",
    "bun-types": "1.3.11",
    "jiti": "^2.7.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
