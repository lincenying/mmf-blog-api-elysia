{
  "name": "mmf-blog-api-elysia",
  "type": "module",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development bun --watch run src/index.ts",
    "build": "bun run build/build.ts",
    "build:compile:mac": "bun run build/build-mac.ts",
    "build:compile:linux": "bun run build/build-linux.ts",
    "build:compile:win": "bun run build/build-win.ts",
    "init:config": "bun run src/init.ts",
    "start": "bun run dist/index.js",
    "db:postgre:generate": "bun drizzle-kit generate",
    "db:postgre:migrate": "bun drizzle-kit migrate",
    "db:sqlite:generate": "bun drizzle-kit generate --config=./drizzle-sqlite.config.ts",
    "db:sqlite:migrate": "bun drizzle-kit migrate --config=./drizzle-sqlite.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ts": "tsc --noEmit",
    "tsc": "tsc"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/html": "^1.4.0",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/server-timing": "^1.4.0",
    "@elysiajs/static": "^1.4.7",
    "@elysiajs/swagger": "^1.3.1",
    "@lincy/utils": "^0.7.3",
    "convict": "^6.2.5",
    "dayjs": "^1.11.20",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "elysia": "^1.4.28",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.2.7",
    "markdown-it": "^14.1.1",
    "md5": "^2.3.0",
    "mongoose": "^9.3.3",
    "mongoose-autopopulate": "^1.2.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "toml": "^3.0.0",
    "twig": "^3.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lincy/eslint-config": "^6.5.2",
    "@types/convict": "^6.1.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/markdown-it": "^14.1.2",
    "@types/md5": "^2.3.6",
    "@types/pg": "^8.20.0",
    "@types/twig": "^1.12.17",
    "bun-types": "1.3.11",
    "jiti": "^2.6.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  }
}
